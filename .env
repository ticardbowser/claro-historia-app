# Copy this to .env and fill in the values

# Generate a strong secret key:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to false in production
DJANGO_DEBUG=false

# Comma-separated list of hostnames that Django will serve
# Include your domain and/or IP, e.g.: myapp.example.com,192.168.1.10
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to your public URL if running behind a proxy (needed for Google OAuth callback)
# Example: https://myapp.example.com
GOOGLE_OAUTH_REDIRECT_BASE=
